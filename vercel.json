{
  "buildCommand": "vite build && node_modules/.bin/esbuild api/_handler.ts --bundle --platform=node --format=cjs --packages=external --outfile=api/index.cjs",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/index.cjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
